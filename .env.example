GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-3-flash-preview

# MCP Server commands
# Docker users: docker-compose.yml injects in-image MCP commands automatically.
# For manual installs, update the paths below to your local MCP server builds.
MCP_DEXSCREENER_CMD=node /path/to/dex-screener-mcp/dist/index.js
MCP_DEXPAPRIKA_CMD=dexpaprika-mcp
MCP_RUGCHECK_CMD=node /path/to/dex-rugcheck-mcp/dist/index.js
MCP_SOLANA_RPC_CMD=node /path/to/solana-rpc-mcp/dist/index.js
MCP_TRADER_CMD=node /path/to/dex-trader-mcp/dist/index.js

# Jupiter API — used by the trader MCP server for Solana swaps.
# lite-api.jup.ag (default) blocks cloud/VPN IPs with 403.
# Get a free API key at https://dev.jup.ag/ to use the authenticated endpoint.
JUPITER_API_BASE=https://api.jup.ag/swap/v1
JUPITER_API_KEY=

# Solana private key — required for the trader MCP to sign transactions.
# This is the base-58 encoded private key of the wallet used for trading.
SOLANA_PRIVATE_KEY=

# Solana RPC URL for on-chain lookups (token decimals, tx verification).
# The public endpoint is heavily rate-limited. For production use a private
# RPC provider (e.g. Helius https://helius.dev or QuickNode https://quicknode.com).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Agent settings
AGENTIC_MAX_ITERATIONS=15
AGENTIC_MAX_TOOL_CALLS=30
AGENTIC_TIMEOUT_SECONDS=120
# Timeout (seconds) for MCP tool calls (e.g. trader swap/quote operations). Increase if
# you see "MCP request timed out: tools/call" errors under slow RPC/network conditions.
MCP_CALL_TIMEOUT=90

LOG_LEVEL=INFO

# Telegram settings (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_PRIVATE_MODE=true
TELEGRAM_SUBSCRIBERS_DB_PATH=

# Portfolio strategy settings (discover → hold → exit at TP/SL)
PORTFOLIO_ENABLED=false
PORTFOLIO_DRY_RUN=true
PORTFOLIO_CHAIN=solana
PORTFOLIO_MAX_POSITIONS=5
PORTFOLIO_POSITION_SIZE_USD=5.00
PORTFOLIO_TAKE_PROFIT_PCT=0.0
PORTFOLIO_STOP_LOSS_PCT=17.0
PORTFOLIO_TRAILING_STOP_PCT=11.0
PORTFOLIO_SELL_PCT=45.0
PORTFOLIO_MAX_HOLD_HOURS=24
PORTFOLIO_DISCOVERY_INTERVAL_MINS=20
PORTFOLIO_PRICE_CHECK_SECONDS=40
PORTFOLIO_DAILY_LOSS_LIMIT_USD=50.0
PORTFOLIO_MIN_VOLUME_USD=380000
PORTFOLIO_MIN_LIQUIDITY_USD=245000
PORTFOLIO_MIN_MARKET_CAP_USD=1650000
PORTFOLIO_MIN_TOKEN_AGE_HOURS=11.0
PORTFOLIO_MAX_TOKEN_AGE_HOURS=0.0
PORTFOLIO_COOLDOWN_SECONDS=300
PORTFOLIO_MIN_MOMENTUM_SCORE=54.0
PORTFOLIO_MAX_SLIPPAGE_BPS=300
# Optional explicit trader method names (auto-detected by default)
PORTFOLIO_QUOTE_METHOD=
PORTFOLIO_EXECUTE_METHOD=
# Default Solana quote mint is USDC
PORTFOLIO_QUOTE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Pre-trade slippage probe: execute a tiny buy+sell to validate real vs quoted slippage
# Set ENABLED=true to activate; probe is always skipped in dry-run mode
PORTFOLIO_SLIPPAGE_PROBE_ENABLED=false
PORTFOLIO_SLIPPAGE_PROBE_USD=0.50
PORTFOLIO_SLIPPAGE_PROBE_MAX_SLIPPAGE_PCT=5.0
# SOL trend gate: pause discovery when SOL drops faster than threshold in lookback window
PORTFOLIO_SOL_DUMP_THRESHOLD_PCT=-5.0
PORTFOLIO_SOL_TREND_LOOKBACK_MINS=60
# Insider / sniper detection: analyse top holders before buying.
# Hard-gate rejects tokens above max thresholds; warn thresholds flag for AI review.
# Keep each WARN threshold below its corresponding MAX threshold.
PORTFOLIO_INSIDER_CHECK_ENABLED=true
PORTFOLIO_INSIDER_MAX_CONCENTRATION_PCT=50.0
PORTFOLIO_INSIDER_MAX_CREATOR_PCT=30.0
PORTFOLIO_INSIDER_WARN_CONCENTRATION_PCT=30.0
PORTFOLIO_INSIDER_WARN_CREATOR_PCT=10.0
# Shadow audit: record approved candidates/positions for outcome comparison alongside real trading.
PORTFOLIO_SHADOW_AUDIT_ENABLED=false
PORTFOLIO_SHADOW_CHECK_MINUTES=30
# Decision logging: persist per-candidate reason codes for pipeline observability
PORTFOLIO_DECISION_LOG_ENABLED=false

# Paid analysis server (server/ directory)
# SERVER_WALLET_ADDRESS — Solana wallet to receive USDC payments (required)
SERVER_WALLET_ADDRESS=
SERVER_PORT=4022
SERVER_SOLANA_NETWORK=solana
SERVER_PRICE_ANALYZE=0.10
# Timeout (ms) for the MCP server's call to the internal Python /analyze endpoint
SERVER_ANALYZE_TIMEOUT_MS=30000
# Timeout (ms) for x402 facilitator settlement requests
SERVER_SETTLE_TIMEOUT_MS=10000
# Internal Docker network URL for the Python analysis API (set automatically by docker-compose)
PYTHON_API_URL=http://api-service:8080
# Shared secret between the TypeScript MCP gateway and the internal FastAPI /analyze endpoint.
# When set, FastAPI rejects any request that does not include a matching X-Internal-API-Key header,
# preventing direct bypass of x402 payment enforcement. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_SECRET=
# Override the default x402 facilitator (optional — default is PayAI mainnet, no auth required)
# Coinbase CDP alternative (requires API keys): https://api.cdp.coinbase.com/platform/v2/x402
# For devnet testing: https://x402.org/facilitator
X402_FACILITATOR_URL=https://facilitator.payai.network
